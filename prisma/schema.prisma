datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  level    String  // honbu / center / dept
  parentId String?
  icon     String  @default("business")

  parent         Organization?  @relation("OrgTree", fields: [parentId], references: [id])
  children       Organization[] @relation("OrgTree")
  members        Member[]
  transferPlans  TransferPlan[]
  headcountPlans HeadcountPlan[]
  futureHeadcounts FutureHeadcount[]
  headcountQuotas  HeadcountQuota[]
  hiringPlans      HiringPlan[]
  transferInPlans  TransferInPlan[]
}

model Member {
  id             String @id @default(cuid())
  empNo          String @unique
  name           String
  orgId          String
  rank           String   @default("")   // 課長, 主任, 一般, 副主任
  transferType   String   @default("")   // 転出（異動）, 退職, or empty
  destDept       String   @default("")
  transferDate   String   @default("")   // "2026年7月" format
  comment        String   @default("")
  approvalStatus String   @default("")   // 承認申請中, 下書き保存, 差戻中, 承認済み
  retirementDate String   @default("")

  // ── 個人情報拡張 ──
  lastNameKana       String   @default("")  // 姓カナ
  firstNameKana      String   @default("")  // 名カナ
  jobResponsibility  String   @default("")  // 職責: グループ長/課長/部長
  jobGrade           String   @default("")  // 職階: A1-A7
  groupType          String   @default("")  // 群類: 管理職/GR3/GR1/GR2
  spec               String   @default("")  // スペック: GR1/2, GR3以上, 契約社員, 60歳以上, 65歳以上
  birthDate          String   @default("")  // 生年月日 (YYYY-MM-DD)
  age                Int?                   // 年齢
  mandatoryRetirementDate String @default("") // 定年退職日 (YYYY-MM-DD)
  salaryRegion       String   @default("")  // 給与管理地区
  isInactive         Boolean  @default(false) // 戦力外フラグ
  returnDate         String   @default("")  // 戦力復帰時期

  org            Organization @relation(fields: [orgId], references: [id])
}

model TransferPlan {
  id       String @id @default(cuid())
  orgId    String
  empNo    String
  name     String
  type     String  // 転出 / 転入 / 退職 / 採用
  dest     String
  date     String  // "2026/07" 形式
  diffKind String  // 計画のみ / 実績のみ / 一致
  org      Organization @relation(fields: [orgId], references: [id])
}

model HeadcountPlan {
  id       String @id @default(cuid())
  orgId    String
  monthIdx Int
  planned  Int
  actual   Int?
  org      Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, monthIdx])
}

model FutureHeadcount {
  id       String @id @default(cuid())
  orgId    String
  monthIdx Int
  count    Int
  comment  String?
  org      Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, monthIdx])
}

model HeadcountQuota {
  id         String @id @default(cuid())
  orgId      String
  fiscalYear Int      // 2026, 2027, 2028
  category   String   // manager(管理職) / staff(一般正社員) / non_regular(非正規)
  q1         Int      // 4-6月
  q2         Int      // 7-9月
  q3         Int      // 10-12月
  q4         Int      // 1-3月
  note       String?
  org        Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, fiscalYear, category])
}

model HiringPlan {
  id         String @id @default(cuid())
  no         String @unique
  position   String
  orgId      String
  type       String              // 新卒 / 中途 / 契約
  count      Int
  targetDate String
  status     String
  note       String   @default("")
  org        Organization @relation(fields: [orgId], references: [id])
}

model TransferInPlan {
  id         String  @id @default(cuid())
  no         String  @unique
  name       String  @default("")
  sourceOrg  String
  sourceType String              // 本部外 / 本部内
  destOrgId  String
  targetDate String
  status     String
  comment    String  @default("")
  isInbound  Boolean @default(false)
  destOrg    Organization @relation(fields: [destOrgId], references: [id])
}

model Snapshot {
  id        String   @id @default(cuid())
  label     String
  date      String
  comment   String?
  createdAt DateTime @default(now())
}

model User {
  id         String  @id @default(cuid())
  azureAdId  String  @unique
  name       String
  email      String
  role       String  // center_manager / hr / planning / manager
  orgId      String?
}
